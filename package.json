{
	"$schema": "https://schemastore.org/package",
	"author": "qwertycxz",
	"bugs": "https://github.com/qwertycxz/acp-to-ws/issues",
	"dependencies": {
		"@agentclientprotocol/sdk": "^1.3.0",
		"ws": "^8.21.1"
	},
	"description": "Redirect ACP to WebSocket",
	"bin": {
		"acp-to-ws": "./dist/index.js"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"@types/ws": "^8.18.1",
		"prettier": "^3.9.6",
		"typescript": "^7.0.2"
	},
	"funding": "https://ko-fi.com/qwertycxz",
	"keywords": [
		"acp"
	],
	"license": "Apache-2.0",
	"main": "./dist/index.js",
	"name": "acp-to-ws",
	"prettier": {
		"arrowParens": "avoid",
		"jsxSingleQuote": true,
		"overrides": [
			{
				"files": "*.yml",
				"options": {
					"tabWidth": 2
				}
			}
		],
		"printWidth": 256,
		"proseWrap": "never",
		"quoteProps": "consistent",
		"semi": false,
		"singleQuote": true,
		"tabWidth": 4,
		"useTabs": true
	},
	"repository": "https://github.com/qwertycxz/acp-to-ws",
	"scripts": {
		"build": "tsc",
		"check": "tsc --noEmit",
		"start": "node dist/index.js"
	},
	"version": "0.0.2"
}
